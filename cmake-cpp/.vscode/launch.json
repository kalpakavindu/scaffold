{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Windows Launch",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "console": "internalConsole"
    },
    {
      "name": "MinGW Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": "${command:cmake.launchTargetEnvironment}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "${input:getCMakeDebugger}",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "getCMakeDebugger",
      "type": "command",
      "command": "cmake.cacheVariable",
      "args": {
        "name": "CMAKE_DEBUGGER"
      }
    }
  ]
}
